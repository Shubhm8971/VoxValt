// app/components/VoiceRecorder-FIXED.tsx
'use client';

import { useState, useEffect, useRef, useCallback } from 'react';
import { useRouter } from 'next/navigation';
import { Mic, Square, Activity } from 'lucide-react';

// Constants
const MAX_RECORDING_SECONDS = 300;
const MIN_RECORDING_SECONDS = 1;
const AUDIO_CONSTRAINTS: MediaTrackConstraints = {
    echoCancellation: true,
    noiseSuppression: true,
    autoGainControl: true,
    sampleRate: 16000,
};

// Enhanced patterns for better recognition
const TASK_PATTERNS = [
    /(?:i need to|need to|should|must|gotta|have to)\s+([^.!?]+)/gi,
    /(?:todo|task)[\s:]*([^.!?]+)/gi,
    /(?:remind me|reminder|remember to)\s+([^.!?]+(?:at|on|by|tomorrow|next|today))/gi,
    /(?:call|contact|email|text)\s+([^.!?]+(?:at|on|by|tomorrow|next|today))/gi,
    /(?:i will|i'll|i am going to|imma)\s+([^.!?]+)/gi,
    /(?:i promise|i'll make sure|i guarantee)\s+([^.!?]+)/gi,
    /(?:every|daily|weekly|monthly|always)\s+([^.!?]+)/gi,
];

// Indian English phrases
const INDIAN_PHRASES = [
    'kal subah 10 baje',
    'meeting kal hai',
    'call karo',
    'bilkul denge',
    'deadline hai',
    'project complete kar do',
];

interface ExtractedData {
    summary: string;
    items: Array<{
        title: string;
        description: string;
        type: 'task' | 'reminder' | 'promise' | 'recurring';
        due_date: string | null;
        people_involved: string[];
        context: string;
    }>;
    tags: string[];
    sentiment: string;
}

interface Task {
    title: string;
    description: string;
    type: 'task' | 'reminder' | 'promise' | 'recurring';
    due_date: string | null;
    people_involved: string[];
    context: string;
}

export default function VoiceRecorder({ 
    userId,
    onTasksExtracted,
    onComplete,
    compact = false 
}: {
    userId: string;
    onTasksExtracted?: (tasks: Task[]) => void;
    onComplete?: () => void;
    compact?: boolean;
}) {
    // State
    const [status, setStatus] = useState<'idle' | 'requesting' | 'recording' | 'paused' | 'processing' | 'success' | 'error'>('idle');
    const [currentTranscript, setCurrentTranscript] = useState('');
    const [duration, setDuration] = useState(0);
    const [audioLevel, setAudioLevel] = useState(0);
    const [waveformData, setWaveformData] = useState<number[]>(new Array(40).fill(0));
    const [error, setError] = useState<string | null>(null);
    const [result, setResult] = useState<ExtractedData | null>(null);

    // Refs
    const mediaRecorderRef = useRef<MediaRecorder | null>(null);
    const streamRef = useRef<MediaStream | null>(null);
    const audioContextRef = useRef<AudioContext | null>(null);
    const analyserRef = useRef<AnalyserNode | null>(null);
    const recognitionRef = useRef<any>(null);
    const timerRef = useRef<NodeJS.Timeout | null>(null);
    const animationRef = useRef<number | null>(null);
    const audioChunksRef = useRef<Blob[]>([]);
    const startTimeRef = useRef<number>(0);

    // Enhanced local extraction
    const extractTasksFromTranscript = useCallback((transcript: string): ExtractedData => {
        console.log('[FIXED] Extracting from transcript:', transcript);
        
        const tasks: Array<{
            title: string;
            description: string;
            type: 'task' | 'reminder' | 'promise' | 'recurring';
            due_date: string | null;
            people_involved: string[];
            context: string;
        }> = [];

        // Enhanced pattern matching
        TASK_PATTERNS.forEach(pattern => {
            const matches = transcript.match(pattern);
            if (matches) {
                const content = matches[1].trim();
                const type = pattern.includes('todo') ? 'task' :
                           pattern.includes('remind') ? 'reminder' :
                           pattern.includes('call') ? 'reminder' :
                           pattern.includes('promise') ? 'promise' :
                           pattern.includes('every') ? 'recurring' : 'task';
                
                // Extract due date
                let dueDate = null;
                const dateMatch = content.match(/(?:by|on|tomorrow|next|today|(\d{1,2}|\d{4}))\s*(?:\d{1,2})/(\d{4}))/i);
                if (dateMatch) {
                    dueDate = dateMatch[0];
                }

                tasks.push({
                    title: content,
                    description: content,
                    type,
                    due_date: dueDate,
                    people_involved: [],
                    context: transcript
                });
            }
        });

        // Check for Indian English phrases
        INDIAN_PHRASES.forEach(phrase => {
            if (transcript.toLowerCase().includes(phrase)) {
                const content = transcript.replace(phrase, '').trim();
                tasks.push({
                    title: phrase,
                    description: content,
                    type: 'task',
                    due_date: null,
                    people_involved: [],
                    context: transcript
                });
            }
        });

        return {
            tasks: tasks.slice(0, 10), // Limit to 10 tasks
            summary: tasks.length > 0 
                ? `Extracted ${tasks.length} task(s) from recording` 
                : 'No speech detected - please speak clearly and try again',
            items: tasks,
            tags: [],
            sentiment: 'neutral'
        };
    }, []);

    // Audio analysis setup
    const setupAudioAnalysis = useCallback((stream: MediaStream) => {
        try {
            const audioContext = new (window.AudioContext || (window as any).webkitAudioContext)();
            const analyser = audioContext.createAnalyser();
            analyser.fftSize = 128;
            analyser.smoothingTimeConstant = 0.75;
            
            const source = audioContext.createMediaStreamSource(stream);
            source.connect(analyser);
            
            audioContextRef.current = audioContext;
            analyserRef.current = analyser;
            
            const updateVisualizer = () => {
                if (!analyserRef.current) return;
                const dataArray = new Uint8Array(analyserRef.current.frequencyBinCount);
                analyserRef.current.getByteFrequencyData(dataArray);
                
                const average = dataArray.reduce((sum, val) => sum + val, 0) / dataArray.length;
                const normalizedLevel = Math.min(average / 128, 1);
                setAudioLevel(normalizedLevel);
                
                const barCount = 40;
                const step = Math.floor(dataArray.length / barCount);
                const bars: number[] = [];
                for (let i = 0; i < barCount; i++) {
                    const index = i * step;
                    bars.push((dataArray[index] || 0) / 255);
                }
                setWaveformData(bars);
                animationRef.current = requestAnimationFrame(updateVisualizer);
            };
            
            updateVisualizer();
        } catch (err) {
            console.warn('[FIXED] Audio analysis setup failed:', err);
        }
    }, []);

    // Speech Recognition setup
    const setupSpeechRecognition = useCallback(() => {
        const SpeechRecognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
        
        if (!SpeechRecognition) {
            console.warn('[FIXED] SpeechRecognition not supported in this browser.');
            return null;
        }
        
        console.log('[FIXED] SpeechRecognition initialized.');
        const recognition = new SpeechRecognition();
        recognition.lang = 'en-IN';
        recognition.continuous = true;
        recognition.interimResults = true;
        recognition.maxAlternatives = 1;
        
        let finalTranscriptAccumulated = '';
        
        recognition.onresult = (event: any) => {
            let interimTranscript = '';
            for (let i = event.resultIndex; i < event.results.length; i++) {
                const transcript = event.results[i][0].transcript;
                if (event.results[i].isFinal) {
                    finalTranscriptAccumulated += transcript + ' ';
                } else {
                    interimTranscript = transcript;
                }
            }
            const fullTranscript = finalTranscriptAccumulated + interimTranscript;
            console.log('[FIXED] Recognition result:', fullTranscript);
            setCurrentTranscript(fullTranscript);
        };
        
        recognition.onerror = (event: any) => {
            console.error('[FIXED] Speech recognition error:', event.error);
            if (event.error === 'not-allowed') {
                setError('Microphone permission denied. Please check settings.');
            }
        };
        
        recognition.onend = () => {
            console.log('[FIXED] Speech recognition ended');
            if (recognitionRef.current && status === 'recording') {
                try { recognition.start(); } catch { }
            }
        };
        
        return recognition;
    }, [status]);

    // Cleanup
    const cleanup = useCallback(() => {
        if (timerRef.current) {
            clearInterval(timerRef.current);
            timerRef.current = null;
        }
        if (animationRef.current) {
            cancelAnimationFrame(animationRef.current);
            animationRef.current = null;
        }
        if (streamRef.current) {
            streamRef.current.getTracks().forEach(track => track.stop());
            streamRef.current = null;
        }
        if (audioContextRef.current?.state !== 'closed') {
            try { audioContextRef.current?.close(); } catch { }
        }
        audioContextRef.current = null;
        analyserRef.current = null;
        recognitionRef.current = null;
        mediaRecorderRef.current = null;
    }, []);

    // Start Recording
    const startRecording = useCallback(async () => {
        try {
            setError(null);
            setResult(null);
            setStatus('requesting');
            setDuration(0);
            setAudioLevel(0);
            setWaveformData(new Array(40).fill(0));
            setCurrentTranscript('');
            
            console.log('[FIXED] Requesting microphone access...');
            const stream = await navigator.mediaDevices.getUserMedia(AUDIO_CONSTRAINTS);
            console.log('[FIXED] Microphone access granted');
            
            streamRef.current = stream;
            
            const mimeType = getSupportedMimeType();
            const mediaRecorder = new MediaRecorder(stream, {
                mimeType,
                audioBitsPerSecond: 128000,
            });
            
            mediaRecorderRef.current = mediaRecorder;
            
            mediaRecorder.ondataavailable = (e) => {
                if (e.data.size > 0) audioChunksRef.current.push(e.data);
            };
            
            mediaRecorder.onerror = (event: any) => {
                console.error('[FIXED] Recording failed:', event.error);
                setError('Recording failed. Please check microphone permissions.');
                cleanup();
            };
            
            mediaRecorder.onstop = async () => {
                console.log('[FIXED] Recording stopped');
                const audioBlob = new Blob(audioChunksRef.current, { type: mimeType });
                
                if (streamRef.current) {
                    streamRef.current.getTracks().forEach(track => track.stop());
                    streamRef.current = null;
                }
                if (audioContextRef.current?.state !== 'closed') {
                    try { await audioContextRef.current?.close(); } catch { }
                }
                audioContextRef.current = null;
                analyserRef.current = null;
                
                const finalDuration = Math.floor((Date.now() - startTimeRef.current) / 1000);
                console.log('[FIXED] Final duration:', finalDuration, 'seconds');
                
                // Enhanced transcript validation
                const transcript = currentTranscript.trim();
                console.log('[FIXED] Final transcript:', transcript);
                
                if (finalDuration < MIN_RECORDING_SECONDS && !transcript) {
                    console.log('[FIXED] Recording too short - returning fallback');
                    setError('Recording too short. Please speak for at least 1 second.');
                    setStatus('error');
                    setAudioLevel(0);
                    setWaveformData(new Array(40).fill(0));
                    return;
                }
                
                // Process recording
                await processRecording(audioBlob, finalDuration);
            };
            
            mediaRecorder.start(500);
            startTimeRef.current = Date.now();
            setStatus('recording');
            setDuration(0);
            
            // Start speech recognition in parallel
            const recognition = setupSpeechRecognition();
            if (recognition) {
                recognitionRef.current = recognition;
                try { recognition.start(); } catch { }
            }
            
            setupAudioAnalysis(stream);
            
        } catch (err: any) {
            console.error('[FIXED] Start failed:', err);
            let errorMessage = 'Failed to start recording.';
            if (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError') {
                errorMessage = 'Microphone access denied. Please check settings.';
            } else if (err.name === 'NotFoundError') {
                errorMessage = 'No microphone found.';
            }
            setError(errorMessage);
            setStatus('error');
        }
    }, [cleanup, setupAudioAnalysis, setupSpeechRecognition]);

    // Stop Recording
    const stopRecording = useCallback(() => {
        console.log('[FIXED] Stopping recording...');
        
        if (recognitionRef.current) {
            try { recognitionRef.current.stop(); } catch { }
            recognitionRef.current = null;
        }
        
        if (timerRef.current) {
            clearInterval(timerRef.current);
            timerRef.current = null;
        }
        
        if (animationRef.current) {
            cancelAnimationFrame(animationRef.current);
            animationRef.current = null;
        }
        
        if (mediaRecorderRef.current && mediaRecorderRef.current.state !== 'inactive') {
            mediaRecorderRef.current.onstop = async () => {
                console.log('[FIXED] MediaRecorder stopped');
                const mimeType = mediaRecorderRef.current?.mimeType || 'audio/webm';
                const audioBlob = new Blob(audioChunksRef.current, { type: mimeType });
                
                if (streamRef.current) {
                    streamRef.current.getTracks().forEach(track => track.stop());
                    streamRef.current = null;
                }
                if (audioContextRef.current?.state !== 'closed') {
                    try { await audioContextRef.current?.close(); } catch { }
                }
                audioContextRef.current = null;
                analyserRef.current = null;
                
                const finalDuration = Math.floor((Date.now() - startTimeRef.current) / 1000);
                console.log('[FIXED] Final duration:', finalDuration, 'seconds');
                
                const transcript = currentTranscript.trim();
                console.log('[FIXED] Final transcript for processing:', transcript);
                
                // Process recording with enhanced error handling
                try {
                    await processRecording(audioBlob, finalDuration);
                } catch (error: any) {
                    console.error('[FIXED] Processing error:', error);
                    // Enhanced fallback
                    const localExtracted = extractTasksFromTranscript(transcript);
                    setResult({
                        transcription: transcript,
                        extracted: localExtracted,
                        items: localExtracted.items.map((item) => ({
                            title: item.title,
                            description: item.description,
                            type: item.type,
                            priority: 'medium',
                            due_date: item.due_date,
                            people_involved: item.people_involved,
                            context: item.context,
                        })),
                        tags: [],
                        sentiment: 'neutral'
                    });
                    setStatus('success');
                    
                    if (localExtracted.tasks.length > 0) {
                        onTasksExtracted?.(localExtracted.tasks as Task[]);
                    }
                }
            }
            
            mediaRecorderRef.current.stop();
        }
        
        if (navigator.vibrate) {
            navigator.vibrate([50, 50, 50]);
        }
        
        setAudioLevel(0);
        setWaveformData(new Array(40).fill(0));
        setStatus('idle');
        setCurrentTranscript('');
        setError(null);
        setResult(null);
    }, [cleanup]);

    // Process Recording with enhanced error handling
    const processRecording = useCallback(
        async (audioBlob: Blob, recordingDuration: number) => {
            setStatus('processing');
            const transcript = currentTranscript.trim();
            
            console.log('[FIXED] Processing audio blob:', audioBlob.size, 'bytes');
            console.log('[FIXED] Transcript before processing:', transcript);
            console.log('[FIXED] Recording duration:', recordingDuration, 'seconds');
            
            // Enhanced transcript validation
            if (!transcript || transcript.length < 2) {
                console.log('[FIXED] Transcript too short or empty, using fallback');
                const fallbackResult = {
                    tasks: [],
                    summary: 'No speech detected - please speak clearly and try again',
                    items: []
                };
                setResult(fallbackResult);
                setStatus('success');
                return;
            }
            
            // Try API first, fallback to local if API fails
            let apiResult: ExtractedData | null = null;
            
            try {
                const formData = new FormData();
                formData.append('audio', audioBlob, `recording.${getExtension(audioBlob.type)}`);
                formData.append('duration', recordingDuration.toString());
                if (transcript) {
                    formData.append('transcript', transcript);
                }
                
                console.log('[FIXED] Sending to API...');
                const response = await fetch('/api/process-voice', {
                    method: 'POST',
                    body: formData,
                });
                
                if (response.ok) {
                    apiResult = await response.json();
                    console.log('[FIXED] API success:', apiResult);
                    setResult(apiResult);
                    setStatus('success');
                    
                    if (apiResult.extracted?.items?.length > 0) {
                        onTasksExtracted?.(apiResult.extracted.items.map((item) => ({
                            title: item.content,
                            description: item.context || '',
                            type: item.type,
                            priority: 'medium',
                            due_date: item.due_date,
                            people_involved: item.people_involved || [],
                            context: item.context || ''
                        })) as Task[]);
                    }
                } else {
                    throw new Error('API request failed');
                }
            } catch (apiError: any) {
                console.error('[FIXED] API error:', apiError);
                
                // Enhanced local fallback
                const localExtracted = extractTasksFromTranscript(transcript);
                console.log('[FIXED] Using local extraction due to API failure');
                
                setResult({
                    transcription: transcript,
                    extracted: localExtracted,
                    items: localExtracted.items.map((item) => ({
                        title: item.title,
                        description: item.description,
                        type: item.type,
                        priority: 'medium',
                        due_date: item.due_date,
                        people_involved: item.people_involved,
                        context: item.context
                    })),
                    tags: [],
                    sentiment: 'neutral'
                });
                setStatus('success');
                
                if (localExtracted.tasks.length > 0) {
                    onTasksExtracted?.(localExtracted.tasks as Task[]);
                }
            }
        },
        [currentTranscript]
    );

    // Helper function
    const getSupportedMimeType = () => {
        const types = [
            'audio/webm;codecs=opus',
            'audio/webm',
            'audio/mp4',
            'audio/ogg;codecs=opus'
        ];
        
        for (const type of types) {
            if (MediaRecorder.isTypeSupported(type)) {
                return type;
            }
        }
        
        return 'audio/webm';
    };

    const getExtension = (mimeType: string) => {
        switch (mimeType) {
            case 'audio/webm': return 'webm';
            case 'audio/mp4': return 'mp4';
            case 'audio/ogg': return 'ogg';
            default: return 'webm';
        }
    };

    // RENDER
    const showProcessing = status === 'processing';
    const showSuccess = status === 'success';
    const showError = status === 'error';
    const showScanner = status === 'recording' || status === 'paused';

    return (
        <div className={`flex flex-col items-center justify-between w-full h-full bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900`}>
            {/* Header */}
            <div className="w-full p-4 border-b border-white/10">
                <div className="flex items-center justify-between">
                    <div className="flex items-center space-x-2">
                        <div className="w-8 h-8 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 flex items-center justify-center">
                            <Mic className="w-4 h-4 text-white" />
                        </div>
                        <div>
                            <h1 className="text-xl font-bold text-white">Vox<span className="text-purple-400">Valt</span></h1>
                            <p className="text-sm text-gray-300">Voice Memory Assistant</p>
                        </div>
                    </div>
                    <div className="flex items-center space-x-4">
                        <div className="text-right">
                            <span className="text-sm text-gray-400">
                                {status === 'idle' ? 'Tap to start' : 
                                 status === 'requesting' ? 'Requesting permission...' :
                                 status === 'recording' ? 'Recording...' :
                                 status === 'paused' ? 'Paused' :
                                 status === 'processing' ? 'Processing...' :
                                 status === 'success' ? 'Success!' :
                                 status === 'error' ? 'Error' : 'Unknown'}
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            {/* Main Content */}
            <div className="flex-1 flex-col items-center justify-center w-full px-4 py-8">
                {showProcessing ? (
                    <div className="text-center">
                        <div className="w-16 h-16 rounded-full border-4 border-purple-500/20 animate-spin flex items-center justify-center">
                            <Activity className="w-6 h-6 text-purple-400" />
                        </div>
                        <h2 className="text-xl font-semibold text-white mt-4">Processing your voice...</h2>
                        <p className="text-gray-300">Extracting tasks and commitments</p>
                    </div>
                ) : (
                    <>
                        {/* Visualizer */}
                        <div className={`w-full max-w-md mx-auto ${compact ? 'h-16' : 'h-32'} transition-all duration-300`}>
                            <div className="flex items-center justify-center w-full h-32">
                                <div className="w-16 h-16 rounded-full bg-white/10 backdrop-blur-sm border border-purple-500/20 flex items-center justify-center">
                                    <Square className="w-6 h-6 text-purple-500" />
                                </div>
                            </div>
                            <div className="flex justify-center space-x-1">
                                {Array.from({ length: 40 }).map((_, i) => (
                                    <div
                                        key={i}
                                        className={`w-1 h-8 bg-purple-500/20 rounded-full transition-all duration-150`}
                                        style={{
                                            height: `${Math.max(4, audioLevel * 16)}px`,
                                            opacity: audioLevel > 0.01 ? 1 : 0.3
                                        }}
                                    />
                                ))}
                            </div>
                        </div>

                        {/* Transcript Display */}
                        <div className="w-full max-w-md mx-auto mt-4">
                            <div className="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-purple-500/20">
                                <div className="flex items-center justify-between mb-4">
                                    <span className="text-sm text-gray-500">Live Transcript</span>
                                    <button
                                        onClick={() => setCurrentTranscript('')}
                                        className="text-xs text-purple-500 underline"
                                    >
                                        Clear
                                    </button>
                                </div>
                                <div className="text-lg font-medium text-gray-800 leading-relaxed">
                                    {currentTranscript || 'Start speaking to see your transcript...'}
                                </div>
                            </div>

                        {/* Controls */}
                        <div className="flex flex-col items-center justify-center w-full space-y-4">
                            <div className="text-center text-sm text-gray-500 mb-2">
                                Duration: {Math.floor(duration / 60)}:{String(duration % 60).padStart(2, '0')}
                            </div>
                            
                            <button
                                onClick={status === 'recording' ? stopRecording : startRecording}
                                className={`w-16 h-16 rounded-full ${
                                    status === 'recording' 
                                        ? 'bg-red-500 hover:bg-red-600 text-white animate-pulse' 
                                        : status === 'paused'
                                        ? 'bg-yellow-500 hover:bg-yellow-600 text-white'
                                        : 'bg-purple-600 hover:bg-purple-700 text-white'
                                } transition-all duration-200 flex items-center justify-center`}
                            >
                                {status === 'recording' ? (
                                    <Square className="w-6 h-6" />
                                ) : (
                                    <Mic className="w-6 h-6" />
                                )}
                            </button>
                            
                            <button
                                onClick={cancelRecording}
                                className="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 transition-colors"
                            >
                                Cancel
                            </button>
                        </div>
                    </div>
                )}
            </>
                )}

                {/* Results */}
                {showSuccess && result && (
                    <div className="w-full max-w-md mx-auto mt-6">
                        <div className="bg-green-500/10 backdrop-blur-sm rounded-2xl p-6 border border-green-500/20">
                            <h3 className="text-lg font-semibold text-white mb-2">Success!</h3>
                            <p className="text-white mb-4">{result.summary}</p>
                            
                            {result.extracted?.items && result.extracted.items.length > 0 && (
                                <div className="space-y-3">
                                    <h4 className="text-white font-medium mb-2">Extracted {result.extracted.items.length} item(s):</h4>
                                    {result.extracted.items.map((item, index) => (
                                        <div key={index} className="bg-white/5 rounded-lg p-4 border border-white/10">
                                            <div className="flex items-start justify-between mb-2">
                                                <span className={`text-xs px-2 py-1 rounded-full ${
                                                    item.type === 'task' ? 'bg-blue-500' :
                                                    item.type === 'reminder' ? 'bg-yellow-500' :
                                                    item.type === 'promise' ? 'bg-green-500' :
                                                    item.type === 'recurring' ? 'bg-purple-500' : 'bg-gray-500'
                                                }`}>
                                                    {item.type.charAt(0).toUpperCase()}
                                                </span>
                                                <div className="flex-1">
                                                    <p className="text-sm font-medium text-white">{item.title}</p>
                                                    <p className="text-xs text-gray-300">{item.description}</p>
                                                </div>
                                            </div>
                                            <div className="text-right">
                                                <button
                                                    onClick={() => {/* TODO: Mark as complete */}}
                                                    className="text-xs text-white underline"
                                                >
                                                    ✓
                                                </button>
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            )}
                        </div>
                    </div>
                )}
            </div>

            {/* Error Display */}
            {showError && (
                <div className="w-full max-w-md mx-auto mt-6">
                    <div className="bg-red-500/10 backdrop-blur-sm rounded-2xl p-6 border border-red-500/20">
                        <h3 className="text-lg font-semibold text-white mb-2">Recording Error</h3>
                        <p className="text-white mb-4">{error}</p>
                        <button
                            onClick={startRecording}
                            className="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors"
                        >
                            Try Again
                        </button>
                    </div>
                )}
            </div>
        </div>
    );
}
