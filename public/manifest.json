// public/manifest.json
{
    "name": "VoxValt - Memory Assistant",
    "short_name": "VoxValt",
    "description": "Never forget what you said you'd do",
    "start_url": "/?source=pwa",
    "display": "standalone",
    "orientation": "portrait",
    "background_color": "#0a0a1a",
    "theme_color": "#667eea",
    "scope": "/",
    "lang": "en",
    "categories": [
        "productivity",
        "utilities"
    ],
    "prefer_related_applications": false,
    "icons": [
        {
            "src": "/icons/icon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "/icons/icon-192-maskable.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "maskable"
        },
        {
            "src": "/icons/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "/icons/icon-512-maskable.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable"
        }
    ],
    "shortcuts": [
        {
            "name": "Record Voice Note",
            "short_name": "Record",
            "url": "/?action=record",
            "icons": [
                {
                    "src": "/icons/icon-192.png",
                    "sizes": "192x192"
                }
            ]
        },
        {
            "name": "Search Memories",
            "short_name": "Search",
            "url": "/search",
            "icons": [
                {
                    "src": "/icons/icon-192.png",
                    "sizes": "192x192"
                }
            ]
        }
    ]
}